{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PAN Shell",
  "version": "0.1.0",
  "identifier": "dev.pan.shell",
  "build": {
    "devUrl": "http://127.0.0.1:7777",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PAN Dashboard",
        "url": "http://127.0.0.1:7777/v2/",
        "width": 1280,
        "height": 800,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "PAN Shell",
      "id": "main"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
